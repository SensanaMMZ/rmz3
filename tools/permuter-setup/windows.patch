+def _compile_argv(compile_cmd: str, c_name: str, o_name: str) -> List[str]:
+    """On Windows the shebang in compile.sh isn't honored by CreateProcess —
+    wrap the call in bash explicitly. On POSIX, execve handles it."""
+    if os.name == "nt" and compile_cmd.endswith(".sh"):
+        return ["C:/devkitPro/msys2/usr/bin/bash.exe", compile_cmd, c_name, "-o", o_name]
+    return [compile_cmd, c_name, "-o", o_name]
+
